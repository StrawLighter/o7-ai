# ============================================================
# WARPATH — Environment Configuration
# Copy to .env and fill in your values
# ============================================================

# --- Solana RPC ---
RPC_URL_PRIMARY=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY
RPC_URL_SECONDARY=https://api.mainnet-beta.solana.com

# --- Wallet (base58 private key OR path to keypair JSON) ---
PRIVATE_KEY=your_base58_private_key_here
# KEYPAIR_PATH=/path/to/keypair.json

# --- Drift Protocol ---
DRIFT_ENV=devnet
DRIFT_MARKET_INDEX=0
DRIFT_SUB_ACCOUNT_ID=0

# --- Safety (BOTH must be true for live trading) ---
WARPATH_LIVE=false
WARPATH_CONFIRM=false

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Candle Timeframe ---
WARPATH_TIMEFRAME=5m
WARPATH_TICK_MS=500

# --- Logging ---
LOG_LEVEL=INFO
TELEMETRY_DIR=./data/logs
